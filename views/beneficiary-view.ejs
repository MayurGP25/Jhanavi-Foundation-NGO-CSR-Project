<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Beneficiaries</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: radial-gradient(circle at top left, #e3f2fd, #f5f7fb);
      min-height: 100vh;
    }

    .app-header {
      backdrop-filter: blur(8px);
      background: rgba(15, 23, 42, 0.92);
    }

    .surface {
      border: none;
      border-radius: 18px;
      box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);
    }

    .btn-pill {
      border-radius: 999px;
    }

    .table thead th {
      border-bottom: none;
    }

    .table-hover tbody tr:hover {
      background: #f2f5ff;
    }

    .mono {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    }

    .avatar {
      width: 38px;
      height: 38px;
      border-radius: 12px;
      background: rgba(37, 99, 235, 0.10);
      color: #1d4ed8;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      border: 1px solid rgba(37, 99, 235, 0.15);
    }

    .soft-badge {
      border-radius: 999px;
      padding: .25rem .7rem;
      font-size: .8rem;
      border: 1px solid rgba(148, 163, 184, 0.35);
      background: rgba(255, 255, 255, 0.65);
      color: #0f172a;
    }

    .empty-state {
      padding: 3rem 1rem;
      text-align: center;
      color: #6c757d;
    }

    .empty-icon {
      font-size: 2.2rem;
      margin-bottom: .75rem;
    }

    .search-input {
      border-radius: 12px;
    }
    .occ-filter-dropdown { position: relative; }
    .occ-filter-toggle {
      width: 100%;
      text-align: left;
      border-radius: 12px;
      background: #fff;
      border: 1px solid #dee2e6;
      padding: 0.375rem 2.25rem 0.375rem 0.75rem;
      background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23343a40' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e");
      background-repeat: no-repeat;
      background-position: right 0.75rem center;
      background-size: 16px 12px;
    }
    .occ-filter-toggle:focus {
      border-color: #86b7fe;
      outline: 0;
      box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
    }
    .occ-filter-options {
      position: absolute;
      z-index: 1050;
      background: #fff;
      border: 1px solid #dee2e6;
      border-radius: 12px;
      width: 100%;
      padding: 0.5rem 0;
      margin-top: 2px;
      max-height: 220px;
      overflow-y: auto;
    }
    .occ-filter-option label {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px 14px;
      cursor: pointer;
      margin: 0;
      font-size: 0.95rem;
    }
    .occ-filter-option label:hover { background: #f0f4ff; }
    .occ-filter-divider { border-top: 1px solid #dee2e6; margin: 4px 0; }
  </style>
</head>

<body>
  <!-- Top App Bar -->
  <nav class="navbar navbar-dark app-header shadow-sm">
    <div class="container">
      <a class="navbar-brand fw-semibold" href="/dashboard">NGO Digital Dashboard</a>
      <div class="d-flex gap-2">
        <a href="/beneficiaries/menu" class="btn btn-outline-light btn-sm btn-pill">Back</a>
        <a href="/logout" class="btn btn-outline-light btn-sm btn-pill">Sign Out</a>
      </div>
    </div>
  </nav>

  <main class="container py-5">
    <!-- Title Row -->
    <div
      class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
      <div>
        <h1 class="fw-bold mb-1">Beneficiaries</h1>
        <p class="text-muted mb-0">Search and review beneficiary profiles.</p>
      </div>
      <div class="d-flex gap-2">
        <a href="/beneficiaries/add" class="btn btn-primary btn-pill">Add Beneficiary</a>
      </div>
    </div>

    <!-- Search & Filter Card -->
    <div class="card surface mb-4">
      <div class="card-body">
        <form method="GET" action="/beneficiaries/view" id="filterForm">
          <div class="row g-3">
            <!-- Name Search -->
            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label small fw-semibold">Beneficiary Name</label>
              <input type="text" name="search" class="form-control search-input" placeholder="Search by name…"
                value="<%= searchQuery %>" />
            </div>

            <!-- Gender Filter -->
            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label small fw-semibold">Gender</label>
              <select name="gender" class="form-select search-input">
                <option value="">All Genders</option>
                <option value="Male" <%=filters && filters.gender==='Male' ? 'selected' : '' %>>Male</option>
                <option value="Female" <%=filters && filters.gender==='Female' ? 'selected' : '' %>>Female</option>
                <option value="Other" <%=filters && filters.gender==='Other' ? 'selected' : '' %>>Other</option>
              </select>
            </div>

            <!-- Marital Status Filter -->
            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label small fw-semibold">Marital Status</label>
              <select name="marital_status" class="form-select search-input">
                <option value="">All Status</option>
                <option value="Unmarried" <%=filters && filters.marital_status==='Unmarried' ? 'selected' : '' %>>Unmarried</option>
                <option value="Married" <%=filters && filters.marital_status==='Married' ? 'selected' : '' %>>Married</option>
                <option value="Divorced" <%=filters && filters.marital_status==='Divorced' ? 'selected' : '' %>>Divorced</option>
                <option value="Widowed" <%=filters && filters.marital_status==='Widowed' ? 'selected' : '' %>>Widowed</option>
              </select>
            </div>

            <!-- Education Filter -->
            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label small fw-semibold">Education</label>
              <input type="text" name="education" class="form-control search-input" placeholder="Filter by education…"
                value="<%= filters && filters.education ? filters.education : '' %>" />
            </div>

            <!-- Location Filter -->
            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label small fw-semibold">Location</label>
              <input type="text" name="location" class="form-control search-input" placeholder="Filter by location…"
                value="<%= filters && filters.location ? filters.location : '' %>" />
            </div>

            <!-- Health Status Filter -->
            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label small fw-semibold">Health Status</label>
              <input type="text" name="health_status" class="form-control search-input"
                placeholder="Filter by health status…"
                value="<%= filters && filters.health_status ? filters.health_status : '' %>" />
            </div>

            <!-- Stay Type Filter -->
            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label small fw-semibold">Stay Type</label>
              <select name="stay_type" class="form-select search-input">
                <option value="">All Stay Types</option>
                <option value="Permanent" <%=filters && filters.stay_type==='Permanent' ? 'selected' : '' %>>Permanent</option>
                <option value="Temporary" <%=filters && filters.stay_type==='Temporary' ? 'selected' : '' %>>Temporary</option>
              </select>
            </div>

            <!-- Age Range -->
            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label small fw-semibold">Min Age</label>
              <input type="number" name="min_age" class="form-control search-input" placeholder="Min age" min="0"
                value="<%= filters && filters.min_age ? filters.min_age : '' %>" />
            </div>

            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label small fw-semibold">Max Age</label>
              <input type="number" name="max_age" class="form-control search-input" placeholder="Max age" min="0"
                value="<%= filters && filters.max_age ? filters.max_age : '' %>" />
            </div>
            <!-- Employment Status Filter -->
            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label small fw-semibold">Employment Status</label>
              <select name="employment_status" class="form-select search-input">
                <option value="">All Status</option>
                <option value="Unemployed" <%=filters && filters.employment_status==='Unemployed' ? 'selected' : '' %>
                  >Unemployed</option>
                <option value="Employed" <%=filters && filters.employment_status==='Employed' ? 'selected' : '' %>
                  >Employed</option>
              </select>
            </div>

            <!-- Occupation Filter -->
            <div class="col-12 col-md-6 col-lg-4">
              <label class="form-label small fw-semibold">Occupation</label>
              <input type="hidden" id="occupation_ids" name="occupation_ids" value="<%= filters && filters.occupation_ids ? filters.occupation_ids : '' %>">
              <div class="occ-filter-dropdown" id="occFilterDropdown">
                <button type="button" class="occ-filter-toggle" id="occFilterToggle" onclick="toggleOccFilterDropdown()">
                  <span id="occFilterDisplay">All Occupations</span>
                </button>
                <div class="occ-filter-options" id="occFilterOptions" style="display:none;">
                  <div class="occ-filter-option">
                    <label>
                      <input type="checkbox" id="occSelectAll" onchange="toggleOccSelectAll(this)">
                      <strong>Select All / Deselect All</strong>
                    </label>
                  </div>
                  <div class="occ-filter-divider"></div>
                  <% jobTypes.forEach(jt => { %>
                  <div class="occ-filter-option">
                    <label>
                      <input type="checkbox" class="occ-filter-cb" value="<%= jt.id %>" data-label="<%= jt.job_type_name %>" onchange="updateOccFilter()">
                      <%= jt.job_type_name %>
                    </label>
                  </div>
                  <% }); %>
                </div>
              </div>
            </div>

            <!-- Action Buttons -->
            <div class="col-12">
              <div class="d-flex gap-2 justify-content-end">
                <a href="/beneficiaries/view" class="btn btn-outline-secondary btn-pill">Clear Filters</a>
                <button type="submit" class="btn btn-dark btn-pill">Apply Filters</button>
              </div>
            </div>
          </div>
        </form>

        <div class="d-flex justify-content-between flex-wrap gap-2 mt-3">
          <div class="text-muted small">
            Tip: Use multiple filters to narrow down results.
          </div>
          <% const hasFilters = searchQuery || (filters && (filters.gender || filters.marital_status || filters.education || filters.location || filters.health_status || filters.stay_type || filters.min_age || filters.max_age || filters.employment_status || filters.occupation_ids)); %>
          <% if (hasFilters) { %>
          <div class="soft-badge">
            Results: <span class="fw-semibold">
              <%= beneficiaries ? beneficiaries.length : 0 %>
            </span>
          </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Table Card -->
    <div class="card surface">
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
              <tr>
                <th style="width:50px;">#</th>
                <th>Beneficiary Name</th>
                <th style="width:60px;">Age</th>
                <th style="width:90px;">Gender</th>
                <th style="width:120px;">Employment Status</th>
                <th>Location</th>
                <th style="width:110px;">Stay Type</th>
                <th style="width:180px;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (!beneficiaries || beneficiaries.length===0) { %>
                <tr>
                  <td colspan="8" class="text-center py-5 text-muted">No records found.</td>
                </tr>
                <% } else { %>
                  <% beneficiaries.forEach(function(b, index) { %>
                    <tr>
                      <td><%= index + 1 %></td>
                      <td class="fw-semibold"><%= b.beneficiary_name %></td>
                      <td><%= (b.age===null || typeof b.age==='undefined') ? '-' : b.age %></td>
                      <td><%= b.gender || '-' %></td>
                      <td><%= b.employment_status || 'Unemployed' %></td>
                      <td><%= b.location || '-' %></td>
                      <td><%= b.stay_type || '-' %></td>
                      <td class="d-flex gap-2">
                        <a href="/beneficiaries/detail/<%= b.id %>" class="btn btn-sm btn-primary btn-pill">View</a>
                        <a href="/beneficiaries/edit/<%= b.id %>" class="btn btn-sm btn-warning btn-pill">Edit</a>
                      </td>
                    </tr>
                    <% }) %>
                      <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Footer Actions -->
    <div class="d-flex justify-content-center mt-4">
      <a href="/beneficiaries/menu" class="btn btn-outline-secondary btn-pill">Back to Beneficiary Menu</a>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function toggleOccFilterDropdown() {
      const opts = document.getElementById('occFilterOptions');
      opts.style.display = opts.style.display === 'none' ? 'block' : 'none';
    }

    function updateOccFilter() {
      const checkboxes = document.querySelectorAll('.occ-filter-cb');
      const selected = Array.from(checkboxes).filter(c => c.checked);
      const ids = selected.map(c => c.value).join(',');
      const labels = selected.map(c => c.dataset.label).join(', ');
      document.getElementById('occupation_ids').value = ids;
      document.getElementById('occFilterDisplay').textContent = labels || 'All Occupations';
      document.getElementById('occSelectAll').checked = selected.length === checkboxes.length && checkboxes.length > 0;
    }

    function toggleOccSelectAll(cb) {
      document.querySelectorAll('.occ-filter-cb').forEach(c => { c.checked = cb.checked; });
      updateOccFilter();
    }

    document.addEventListener('click', function(e) {
      const dropdown = document.getElementById('occFilterDropdown');
      if (!dropdown.contains(e.target)) {
        document.getElementById('occFilterOptions').style.display = 'none';
      }
    });

    // Restore active filter selections on page load
    const activeOccIds = document.getElementById('occupation_ids').value;
    if (activeOccIds) {
      const active = activeOccIds.split(',');
      document.querySelectorAll('.occ-filter-cb').forEach(cb => {
        if (active.includes(cb.value)) cb.checked = true;
      });
      updateOccFilter();
    }
  </script>
</body>
</html>