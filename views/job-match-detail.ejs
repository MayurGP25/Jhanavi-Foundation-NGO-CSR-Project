<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Match Detail</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        body {
            background: radial-gradient(circle at top left, #e3f2fd, #f5f7fb);
            min-height: 100vh;
        }
        .app-header {
            backdrop-filter: blur(8px);
            background: rgba(15, 23, 42, 0.92);
        }
        .surface {
            border: none;
            border-radius: 18px;
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);
        }
        .btn-pill {
            border-radius: 999px;
        }
        .section-title {
            font-weight: 700;
            font-size: 1.6rem;
            letter-spacing: 0.02em;
            color: #0f172a;
            margin-top: 1.25rem;
            margin-bottom: 0.75rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid rgba(148, 163, 184, 0.45);
        }
        .form-control, textarea {
            border-radius: 12px;
        }
        textarea {
            min-height: 90px;
        }
        .occ-badge {
            display: inline-flex;
            align-items: center;
            background: #e8f0fe;
            color: #1a56db;
            border: 1px solid rgba(26, 86, 219, 0.2);
            border-radius: 999px;
            padding: 0.25rem 0.75rem;
            font-size: 0.82rem;
            font-weight: 500;
        }
        .occ-badge-wrap {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
            min-height: 38px;
            align-items: center;
            padding: 0.375rem 0.5rem;
            background: #f8f9fa;
            border: 1px solid #dee2e6;
            border-radius: 12px;
        }
        .match-banner {
            border: none;
            border-radius: 14px;
            background: linear-gradient(135deg, #16a34a, #15803d);
            color: #fff;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark app-header shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-semibold" href="/dashboard">NGO Digital Dashboard</a>
            <div class="d-flex gap-2">
                <a href="/jobmatching/matched" class="btn btn-outline-light btn-sm btn-pill">Back</a>
                <a href="/logout" class="btn btn-outline-light btn-sm btn-pill">Sign Out</a>
            </div>
        </div>
    </nav>

    <main class="container py-5">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
            <div>
                <h1 class="fw-bold mb-1" style="color: #000;">Match Detail</h1>
                <p class="text-muted mb-0">Employment match record (read-only)</p>
            </div>
        </div>

        <!-- Match summary banner -->
        <div class="card match-banner p-3 mb-4">
            <div class="d-flex flex-wrap gap-3 align-items-center">
                <div>
                    <div class="small opacity-75">Beneficiary</div>
                    <div class="fw-bold fs-5"><%= match.beneficiary_name %></div>
                </div>
                <div class="vr opacity-25 d-none d-md-block" style="height:40px;"></div>
                <div>
                    <div class="small opacity-75">Placed at</div>
                    <div class="fw-bold fs-5"><%= match.provider_name %></div>
                </div>
                <% if (match.employment_start_date) { %>
                <div class="vr opacity-25 d-none d-md-block" style="height:40px;"></div>
                <div>
                    <div class="small opacity-75">From</div>
                    <div class="fw-bold">
                        <%= new Date(match.employment_start_date).toLocaleDateString('en-IN', { day: '2-digit', month: 'long', year: 'numeric' }) %>
                    </div>
                </div>
                <% } %>
            </div>
        </div>

        <div class="card surface">
            <div class="card-body p-4 p-md-5">

                <div class="section-title">Match Details</div>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-semibold">Role in Company</label>
                        <input type="text" class="form-control" value="<%= match.role_in_company || '' %>" disabled>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-semibold">Employment Start Date</label>
                        <input type="text" class="form-control" value="<%= match.employment_start_date ? new Date(match.employment_start_date).toLocaleDateString('en-IN', { day: '2-digit', month: 'long', year: 'numeric' }) : '' %>" disabled>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Remarks</label>
                        <textarea class="form-control" rows="3" disabled><%= match.remarks || '' %></textarea>
                    </div>
                </div>

                <div class="section-title">Beneficiary Information</div>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-semibold">Beneficiary Name</label>
                        <input type="text" class="form-control" value="<%= match.beneficiary_name %>" disabled>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-semibold">Contact Number</label>
                        <input type="text" class="form-control" value="<%= match.contact_no || '' %>" disabled>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-semibold">Location</label>
                        <input type="text" class="form-control" value="<%= match.location || '' %>" disabled>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-semibold">Occupation(s)</label>
                        <div class="occ-badge-wrap">
                            <% if (occupationNames.length) { %>
                                <% occupationNames.forEach(name => { %>
                                    <span class="occ-badge"><%= name %></span>
                                <% }); %>
                            <% } else { %>
                                <span style="color:#6c757d;font-size:.9rem;">—</span>
                            <% } %>
                        </div>
                    </div>
                </div>

                <div class="section-title">Job Provider Information</div>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-semibold">Provider Name</label>
                        <input type="text" class="form-control" value="<%= match.provider_name %>" disabled>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-semibold">Contact Person</label>
                        <input type="text" class="form-control" value="<%= match.contact_person || '' %>" disabled>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-semibold">Phone</label>
                        <input type="text" class="form-control" value="<%= match.phone || '' %>" disabled>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-semibold">City</label>
                        <input type="text" class="form-control" value="<%= match.city || '' %>" disabled>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-semibold">State</label>
                        <input type="text" class="form-control" value="<%= match.state || '' %>" disabled>
                    </div>
                </div>

                <div class="d-flex flex-column flex-sm-row gap-2 justify-content-end mt-4">
                    <a href="/jobmatching/matched" class="btn btn-outline-secondary btn-pill">Back to List</a>
                    <a href="/beneficiaries/detail/<%= match.beneficiary_id %>" class="btn btn-outline-primary btn-pill">View Beneficiary Profile</a>
                </div>

            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
