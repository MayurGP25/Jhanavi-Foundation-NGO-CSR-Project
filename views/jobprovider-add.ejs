<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= jobProvider ? 'Edit' : 'Add' %> Job Provider</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

  <style>
    body { background: radial-gradient(circle at top left, #e3f2fd, #f5f7fb); min-height: 100vh; }
    .app-header { backdrop-filter: blur(8px); background: rgba(15, 23, 42, 0.92); }
    .surface { border: none; border-radius: 18px; box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12); }
    .btn-pill { border-radius: 999px; }
    .section-title {
      font-weight: 700;
      font-size: 0.95rem;
      letter-spacing: 0.02em;
      color: #0f172a;
      margin-top: 1.25rem;
      margin-bottom: 0.75rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid rgba(148, 163, 184, 0.45);
    }
    .form-control, .form-select, textarea { border-radius: 12px; }
    textarea { min-height: 110px; }
    .help { font-size: .85rem; color: #6c757d; }
    .jobtype-dropdown { position: relative; }
    .jobtype-toggle {
      width: 100%;
      text-align: left;
      border-radius: 12px;
      background: #fff;
      border: 1px solid #dee2e6;
      padding: 0.375rem 2.25rem 0.375rem 0.75rem;
      background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23343a40' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e");
      background-repeat: no-repeat;
      background-position: right 0.75rem center;
      background-size: 16px 12px;
    }
    .jobtype-toggle:focus {
      border-color: #86b7fe;
      outline: 0;
      box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
    }
    .jobtype-options {
      position: absolute;
      z-index: 1050;
      background: #fff;
      border: 1px solid #dee2e6;
      border-radius: 12px;
      width: 100%;
      padding: 0.5rem 0;
      margin-top: 2px;
      max-height: 220px;
      overflow-y: auto;
    }
    .jobtype-option label {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px 14px;
      cursor: pointer;
      margin: 0;
      font-size: 0.95rem;
    }
    .jobtype-option label:hover { background: #f0f4ff; }
    .jobtype-option-divider { border-top: 1px solid #dee2e6; margin: 4px 0; }
  </style>
</head>

<body>
  <nav class="navbar navbar-dark app-header shadow-sm">
    <div class="container">
      <a class="navbar-brand fw-semibold" href="/dashboard">NGO Digital Dashboard</a>
      <div class="d-flex gap-2">
        <a href="/jobproviders/menu" class="btn btn-outline-light btn-sm btn-pill">Back</a>
        <a href="/logout" class="btn btn-outline-light btn-sm btn-pill">Sign Out</a>
      </div>
    </div>
  </nav>

  <main class="container py-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
      <div>
        <h1 class="fw-bold mb-1"><%= jobProvider ? 'Edit' : 'Add' %> Job Provider</h1>
        <p class="text-muted mb-0">Maintain partner organization details and assigned job types.</p>
      </div>
    </div>

    <div class="card surface">
      <div class="card-body p-4 p-md-5">
        <form id="jobProviderForm" method="POST" action="<%= jobProvider ? `/jobproviders/edit/${jobProvider.id}` : '/jobproviders/add' %>">

          <div class="section-title">Organization</div>

          <div class="row g-3">
            <div class="col-12 col-md-6">
              <label class="form-label fw-semibold">Provider Name *</label>
              <input type="text" class="form-control" name="provider_name" value="<%= jobProvider ? jobProvider.provider_name : '' %>" required />
            </div>

            <div class="col-12 col-md-6">
              <label class="form-label fw-semibold">Contact Person *</label>
              <input type="text" class="form-control" name="contact_person" value="<%= jobProvider ? jobProvider.contact_person : '' %>" required />
            </div>

            <div class="col-12 col-md-6">
              <label class="form-label fw-semibold">Phone *</label>
              <input type="tel" class="form-control" name="phone" pattern="[0-9]*" placeholder="Numbers only" value="<%= jobProvider ? jobProvider.phone : '' %>" required />
            </div>

            <div class="col-12 col-md-6">
              <label class="form-label fw-semibold">Email</label>
              <input type="email" class="form-control" name="email" placeholder="example@domain.com" value="<%= jobProvider ? jobProvider.email : '' %>" />
            </div>
          </div>

          <div class="section-title">Job Types</div>

          <div class="row g-3">
            <div class="col-12">
              <label class="form-label fw-semibold">Select Job Types</label>
              <input type="hidden" id="job_type_ids" name="job_type_ids">
              <div class="jobtype-dropdown" id="jobtypeDropdown">
                <button type="button" class="jobtype-toggle form-select text-start" id="jobtypeToggle" onclick="toggleJobtypeDropdown()">
                  <span id="jobtypeDisplay">Select job type(s)</span>
                </button>
                <div class="jobtype-options" id="jobtypeOptions" style="display:none;">
                  <div class="jobtype-option">
                    <label>
                      <input type="checkbox" id="selectAllJobTypes" onchange="toggleSelectAllJobTypes(this)">
                      <strong>Select All / Deselect All</strong>
                    </label>
                  </div>
                  <div class="jobtype-option-divider"></div>
                  <% jobTypes.forEach(jt => { %>
                  <div class="jobtype-option">
                    <label>
                      <input type="checkbox" class="jobtype-checkbox" value="<%= jt.id %>" data-label="<%= jt.job_type_name %>" onchange="updateJobtypeValue()">
                      <%= jt.job_type_name %>
                    </label>
                  </div>
                  <% }); %>
                </div>
              </div>
            </div>
          </div>

          <div class="section-title">Address</div>

          <div class="row g-3">
            <div class="col-12">
              <label class="form-label fw-semibold">Address *</label>
              <input type="text" class="form-control" name="address" value="<%= jobProvider ? jobProvider.address : '' %>" required />
            </div>

            <div class="col-12 col-md-4">
              <label class="form-label fw-semibold">City *</label>
              <input type="text" class="form-control" name="city" value="<%= jobProvider ? jobProvider.city : '' %>" required />
            </div>

            <div class="col-12 col-md-4">
              <label class="form-label fw-semibold">State *</label>
              <input type="text" class="form-control" name="state" value="<%= jobProvider ? jobProvider.state : '' %>" required />
            </div>

            <div class="col-12 col-md-4">
              <label class="form-label fw-semibold">Pincode *</label>
              <input type="text" class="form-control" name="pincode" value="<%= jobProvider ? jobProvider.pincode : '' %>" required />
            </div>
          </div>

          <div class="section-title">Additional Notes</div>

          <div class="row g-3">
            <div class="col-12">
              <label class="form-label fw-semibold">Notes</label>
              <textarea class="form-control" name="notes"><%= jobProvider ? jobProvider.notes : '' %></textarea>
            </div>
          </div>

          <div class="d-flex flex-column flex-sm-row gap-2 justify-content-end mt-4">
            <a href="/jobproviders/menu" class="btn btn-outline-secondary btn-pill">Cancel</a>
            <button type="submit" class="btn btn-success btn-pill">
              <%= jobProvider ? 'Update Provider' : 'Save Provider' %>
            </button>
          </div>
        </form>
      </div>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function toggleJobtypeDropdown() {
      const opts = document.getElementById('jobtypeOptions');
      opts.style.display = opts.style.display === 'none' ? 'block' : 'none';
    }

    function updateJobtypeValue() {
      const checkboxes = document.querySelectorAll('.jobtype-checkbox');
      const selected = Array.from(checkboxes).filter(c => c.checked);
      const ids = selected.map(c => c.value).join(',');
      const labels = selected.map(c => c.dataset.label).join(', ');
      document.getElementById('job_type_ids').value = ids;
      document.getElementById('jobtypeDisplay').textContent = labels || 'Select job type(s)';
      document.getElementById('selectAllJobTypes').checked = selected.length === checkboxes.length;
    }

    function toggleSelectAllJobTypes(cb) {
      document.querySelectorAll('.jobtype-checkbox').forEach(c => { c.checked = cb.checked; });
      updateJobtypeValue();
    }

    document.addEventListener('click', function(e) {
      const dropdown = document.getElementById('jobtypeDropdown');
      if (!dropdown.contains(e.target)) {
        document.getElementById('jobtypeOptions').style.display = 'none';
      }
    });

    // Pre-select for edit mode
    const preSelected = <%- JSON.stringify(selectedJobTypeIds) %>;
    if (preSelected && preSelected.length) {
      document.querySelectorAll('.jobtype-checkbox').forEach(cb => {
        if (preSelected.includes(parseInt(cb.value))) cb.checked = true;
      });
      updateJobtypeValue();
    }
  </script>
</body>
</html>